# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rain_alert?schema=public"

# Supabase. Use Supabase Postgres for DATABASE_URL and Storage for shared KNMI raster cache.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="rain-alert"
SUPABASE_STORAGE_KNMI_PREFIX="knmi-nowcast"

# KNMI Data Platform Open Data API. Keep this server-side only.
KNMI_API_KEY=""
KNMI_DATASET_NAME="radar_forecast"
KNMI_DATASET_VERSION="2.0"
KNMI_CACHE_TTL_SECONDS="240"
KNMI_HDF5_DATASET_PATH=""
KNMI_GRID_BOUNDS="3.0,50.6,7.5,53.8"

# Open-Meteo fallback
OPEN_METEO_BASE_URL="https://api.open-meteo.com/v1/forecast"

# Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@example.org"

# MailerSend email notifications. Keep token server-side only.
MAILERSEND_API_TOKEN=""
MAILERSEND_FROM_EMAIL="alerts@example.org"
MAILERSEND_FROM_NAME="Rain Alert"

# Cron protection
CRON_SECRET="change-me"

# Demo/fallback provider
ENABLE_BUIENRADAR_DEMO="false"

# Runtime
NEXT_PUBLIC_APP_URL="http://localhost:3000"
